pipeline {
	agent {
		// docker { image 'python:3.9' }
		docker {
			image 'python:3.11-slim'
			args '-v /var/run/docker.sock:/var/run/docker.sock'
		}
		// node {
		// 	label '' // An empty label string means "any"
		// }
	}
	// environment { }

	stages {
		stage('Sync Repo') {
			steps {
				checkout scm
			}
		}
		stage('Verify Tools') {
			steps {
				sh 'python3 --version'
				sh 'docker --version'
			}
		}
		stage ('Logging') {
			steps {
				echo "Current branch is: ${env.GIT_BRANCH}"
				sh "bash ci-cd/jenkins/scripts/hello.sh"
			}
		}
		stage ('Deploy') {
			when {
				expression { return env.GIT_BRANCH.contains ('prod') }
			}
			steps {
				dir ("ci-cd") {
					sh 'bash jenkins/scripts/deploy.sh'
				}
			}
		}
	}

	post {
		always {
			echo 'Cleanup'
		}
		success {
			echo 'Success'
		}
		failure {
			echo 'Failure'
		}
	}
}
