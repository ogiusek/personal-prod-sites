pipeline {
	agent {
		node {
			label '' // An empty label string means "any"
		}
	}
	// environment { }

	stages {
		stage('Sync Repo') {
			steps {
				checkout scm
			}
		}
		stage ('Logging') {
			steps {
				echo "Current branch is: ${env.GIT_BRANCH}"
			}
		}
		stage ('Security scans') {
			steps {
				dir ("ci-cd"){
					sh 'trivy config --exit-code 1 --severity HIGH,CRITICAL .'
				}
			}
		}
		stage ('Deploy') {
			when {
				expression { return env.GIT_BRANCH.contains ('prod') }
			}
			steps {
				dir ("ci-cd") {
					sh 'bash jenkins/scripts/deploy.sh'
				}
			}
		}
	}

	post {
		always {
			echo 'Cleanup'
		}
		success {
			echo 'Success'
		}
		failure {
			echo 'Failure'
		}
	}
}
