pipeline {
	agent {
		node {
			label '' // An empty label string means "any"
		}
	}
	environment {
		SSH_CRED_ID = "836d01e5-f47e-4801-a5e2-c274f8c511f0"
	}

	stages {
		stage('Debug') {
			steps {
				echo 'Stage Debug runned!'
			}
		}
		stage('Logging') {
			steps {
				script {
					echo "Current branch is: ${env.GIT_BRANCH}"
				}
			}
		}
		stage('Deploy') {
			when {
				expression { return env.GIT_BRANCH.toLowerCase()?.contains('prod') }
			}
			steps {
				dir('/personal-prod-sites/ci-cd') {
					withCredentials([sshUserPrivateKey(credentialsId: "${env.SSH_CRED_ID}", keyFileVariable: 'SSH_KEY_FILE')]) {
						sh 'git config --global --add safe.directory /personal-prod-sites'
						sh 'git checkout ${GIT_BRANCH}'
						sh 'git pull'
					}
					sh 'docker compose up -d --build --remove-orphans'
				}
			}
		}
	}

	post {
		always {
			echo 'Cleanup'
		}
		success {
			echo 'Success'
		}
		failure {
			echo 'Failure'
		}
	}
}
