pipeline {
	agent {
		node {
			label '' // An empty label string means "any"
		}
	}
	environment {
		REPO_URL = 'https://github.com/ogiusek/personal-prod-sites.git';
		SSH_CRED_ID = "836d01e5-f47e-4801-a5e2-c274f8c511f0"
	}

	stages {
		stage('Sync Repo') {
			steps {
				// git "${REPO_URL}"
// ci-cd/jenkins/scripts/hello.sh
				checkout scm
				// checkout scm:[
				// 	$ class :'GitSCM',
				// 	        branches :[[name :'*/main']],
				// 	        userRemoteConfigs :[[url :env.REPO_URL, credentialsId :env.SSH_CRED_ID]]
				// ]
			}
		}
		stage ('Logging') {
			steps {
				script {
					echo "Current branch is: ${env.GIT_BRANCH}"
					sh "bash ${WORKSPACE}/ci-cd/jenkins/scripts/hello.sh"
				}
			}
		}
		stage ('Deploy') {
			when {
				expression { return env.GIT_BRANCH.contains ('prod') }
			}
			steps {
				dir ("${WORKSPACE}/ci-cd") {
					sh 'docker compose up -d --build --remove-orphans'
				}
			}
		}
	}

	post {
		always {
			echo 'Cleanup'
		}
		success {
			echo 'Success'
		}
		failure {
			echo 'Failure'
		}
	}
}
