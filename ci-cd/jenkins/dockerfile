FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    openjdk-21-jre \
    curl \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

ARG JENKINS_VERSION=2.541.2
RUN curl -L -o /usr/share/jenkins.war http://updates.jenkins-ci.org/download/war/${JENKINS_VERSION}/jenkins.war

ENV JENKINS_HOME /var/jenkins_home
RUN mkdir -p $JENKINS_HOME && useradd -d "$JENKINS_HOME" -u 1000 -m -s /bin/bash jenkins

RUN chown -R jenkins:jenkins $JENKINS_HOME

USER jenkins
WORKDIR $JENKINS_HOME

ENTRYPOINT ["java", "-jar", "/usr/share/jenkins.war"]
