FROM debian:bookworm-slim

# Install OpenJDK (Jenkins is a Java app)
RUN apt-get update && apt-get install -y \
    openjdk-17-jre \
    curl \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Download the Jenkins WAR file directly
ARG JENKINS_VERSION=2.440.2
RUN curl -L -o /usr/share/jenkins.war http://updates.jenkins-ci.org/download/war/${JENKINS_VERSION}/jenkins.war

# Set up the Jenkins user and home directory
ENV JENKINS_HOME /var/jenkins_home
RUN mkdir -p $JENKINS_HOME && useradd -d "$JENKINS_HOME" -u 1000 -m -s /bin/bash jenkins

EXPOSE 8080 9191

USER jenkins

# Run Jenkins directly via Java
ENTRYPOINT ["java", "-jar", "/usr/share/jenkins.war"]
